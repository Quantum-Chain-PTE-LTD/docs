{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Quantum Chain Custody",
  "colors": {
    "primary": "#7C3AED",
    "light": "#A78BFA",
    "dark": "#5B21B6"
  },
  "favicon": "/favicon.svg",
  "openapi": ["/api-reference/openapi.json"],
  "appearance": {
    "default": "dark"
  },
  "background": {
    "color": {
      "light": "#FFFFFF",
      "dark": "#0F172A"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "authentication",
              "architecture"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/vaults-wallets",
              "concepts/transactions",
              "concepts/policies",
              "concepts/webhooks",
              "concepts/quantum-safety",
              "concepts/state-machine"
            ]
          },
          {
            "group": "Development",
            "pages": [
              "development"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Health",
            "pages": [
              "api-reference/endpoint/health",
              "api-reference/endpoint/readiness"
            ]
          },
          {
            "group": "Tenants",
            "pages": [
              "api-reference/endpoint/create",
              "api-reference/endpoint/list-tenants",
              "api-reference/endpoint/get"
            ]
          },
          {
            "group": "Vaults",
            "pages": [
              "api-reference/endpoint/create-vault",
              "api-reference/endpoint/list-vaults",
              "api-reference/endpoint/get-vault"
            ]
          },
          {
            "group": "Wallets",
            "pages": [
              "api-reference/endpoint/register-wallet",
              "api-reference/endpoint/list-wallets",
              "api-reference/endpoint/get-wallet",
              "api-reference/endpoint/get-balance"
            ]
          },
          {
            "group": "Transactions",
            "pages": [
              "api-reference/endpoint/create-transaction",
              "api-reference/endpoint/list-transactions",
              "api-reference/endpoint/get-transaction",
              "api-reference/endpoint/get-signing-payload",
              "api-reference/endpoint/submit-signature",
              "api-reference/endpoint/approve-transaction",
              "api-reference/endpoint/reject-transaction",
              "api-reference/endpoint/cancel-transaction"
            ]
          },
          {
            "group": "Assets",
            "pages": [
              "api-reference/endpoint/list-vault-assets",
              "api-reference/endpoint/get-vault-asset",
              "api-reference/endpoint/list-assets",
              "api-reference/endpoint/get-asset"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "api-reference/endpoint/webhook",
              "api-reference/endpoint/list-webhooks",
              "api-reference/endpoint/delete"
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Guides",
            "pages": [
              "guides/external-signing",
              "guides/transaction-lifecycle"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Community",
          "href": "https://discord.gg/quantumchain",
          "icon": "discord"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/Quantum-Chain-PTE-LTD",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@quantumchain.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.quantumchain.io"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "seo": {
    "metatags": {
      "canonical": "https://docs.quantumapi.io"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Quantum-Chain-PTE-LTD",
      "x": "https://x.com/quantumchain",
      "discord": "https://discord.gg/quantumchain"
    }
  }
